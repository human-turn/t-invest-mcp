{
  "name": "t-invest-mcp",
  "version": "0.1.1",
  "description": "MCP server for T-Invest API (Tinkoff Investments): portfolio, market data, dividends, bonds, fundamentals, optional trading and sandbox",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "t-invest-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/human-turn/t-invest-mcp.git"
  },
  "homepage": "https://github.com/human-turn/t-invest-mcp#readme",
  "bugs": "https://github.com/human-turn/t-invest-mcp/issues",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tinkoff",
    "t-invest",
    "t-bank",
    "investments"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@tinkoff/invest-js": "^1.27.1-RC4",
    "fflate": "^0.8.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
