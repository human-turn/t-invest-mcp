# Демо slash-команд (ритуалов) для раздела «Готовое из коробки».
# Рендер из корня репо: vhs docs/vhs/demo-rituals.tape
Output docs/demo-rituals.gif

Set Shell bash
Set FontSize 15
Set Width 1000
Set Height 640
Set Padding 18
Set TypingSpeed 55ms

Hide
Type "cd docs/vhs && clear && ./repl.sh answers-rituals-1.txt"
Enter
Show

Sleep 1s
Type "/mcp__t-invest__quarterly"
Sleep 700ms
Enter
Sleep 11s
